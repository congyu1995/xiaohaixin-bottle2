# MongoDB连接字符串（必填）
# 格式: mongodb+srv://用户名:密码@cluster.mongodb.net/数据库名
MONGODB_URI=mongodb+srv://moodbottle:your_password@cluster0.xxxxx.mongodb.net/mood-bottle?retryWrites=true&w=majority

# 服务器端口（Railway自动设置）
PORT=3001

# 运行环境
NODE_ENV=production

# 前端URL（用于CORS配置，可选）
# 部署前端后填入Vercel域名
CLIENT_URL=https://your-app.vercel.app

# ========================================
# 如何获取MongoDB连接字符串:
# ========================================
# 1. 访问 https://www.mongodb.com/cloud/atlas
# 2. 选择你的集群，点击 "Connect"
# 3. 选择 "Connect your application"
# 4. Driver: Node.js, Version: 5.5 or later
# 5. 复制连接字符串
# 6. 将 <password> 替换为你的数据库密码
# 7. 确保IP白名单设置为 0.0.0.0/0
